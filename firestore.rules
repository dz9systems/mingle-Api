rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function isHostOf(eventDoc) {
      return isSignedIn()
        && eventDoc != null
        && (
          eventDoc.data.hostId == request.auth.uid
          || ('hostIds' in eventDoc.data
            && eventDoc.data.hostIds.hasAny([request.auth.uid]))
        );
    }

    // Allow a signed-in user to add themselves as co-host via a valid invite link.
    function isJoiningAsCohost() {
      return isSignedIn()
        && resource.data.cohostToken is string
        && resource.data.cohostToken.size() > 0
        && request.resource.data.cohostToken == resource.data.cohostToken
        && request.resource.data.hostId == resource.data.hostId
        && !isHostOf(resource)
        && request.resource.data.hostIds.hasAll(
          ('hostIds' in resource.data) ? resource.data.hostIds : [resource.data.hostId]
        )
        && request.resource.data.hostIds.hasAny([request.auth.uid])
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['hostIds', 'hosts']);
    }

    match /events/{slug} {
      allow read: if true;

      allow create: if isSignedIn()
                     && request.resource.data.hostId == request.auth.uid
                     && request.auth.uid in request.resource.data.hostIds;

      allow update: if isHostOf(resource) || isJoiningAsCohost();
      allow delete: if isHostOf(resource);

      match /rsvps/{uid} {
        allow read: if true;
        allow write: if (isSignedIn() && request.auth.uid == uid)
                      || uid.matches('^guest-.+');
      }

      // Potluck uses a `claims` array (not legacy `claimedBy`). Guests are not
      // Firebase-authenticated, so claim/unclaim updates must be open like songs.
      match /potluck/{itemId} {
        allow read: if true;
        allow create, update: if true;
        allow delete: if isHostOf(get(/databases/$(database)/documents/events/$(slug)));
      }

      match /songs/{songId} {
        allow read: if true;
        allow create, update: if true;
        allow delete: if isHostOf(get(/databases/$(database)/documents/events/$(slug)));
      }

      match /teamAssignments/{uid} {
        allow read: if true;
        allow write: if (isSignedIn() && request.auth.uid == uid)
                      || uid.matches('^guest-.+');
      }
    }

    match /smsLog/{logId}     { allow read, write: if false; }
    match /emailLog/{logId}   { allow read, write: if false; }
    match /rateLimits/{uid}   { allow read, write: if false; }
    match /hostIntegrations/{uid} { allow read, write: if false; }
    match /calendarEvents/{slug}  { allow read, write: if false; }
  }
}
