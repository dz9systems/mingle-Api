RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL=Mingle <invites@mail.themingleapp.com>
# Fallback when the signed-in host has no email on their Firebase account
RESEND_REPLY_TO=themingleapp@gmail.com
TWILIO_ACCOUNT_SID=ACxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxx
TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxx
# Optional: send from a specific number instead of the messaging service sender pool
TWILIO_FROM_NUMBER=+18443265851
RATELIMIT_EMAIL_PER_HOUR=500
RATELIMIT_EMAIL_PER_DAY=2000
RATELIMIT_SMS_PER_HOUR=200
RATELIMIT_SMS_PER_DAY=500
RATELIMIT_IP_PER_HOUR=60
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://mingle.app,https://www.themingleapp.com
FRONTEND_URL=https://www.themingleapp.com
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxxxxx
# Must match an authorized redirect URI in Google Cloud Console
GOOGLE_OAUTH_REDIRECT_URI=https://www.themingleapp.com/api/integrations/google/calendar/callback
# Optional: separate secret for signing OAuth state (defaults to client secret)
GOOGLE_OAUTH_STATE_SECRET=random-long-secret
SPOTIFY_CLIENT_ID=xxxxxxxx
SPOTIFY_CLIENT_SECRET=xxxxxxxx
